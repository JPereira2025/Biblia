<?xml version='1.0' encoding='utf-8'?>
<widget id="com.example.bibleapp" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Biblia</name>
    <description>
        Aplicación de la Biblia empaquetada con Cordova.
    </description>
    <author email="dev@cordova.apache.org" href="https://cordova.apache.org">
        Apache Cordova Team
    </author>
    <content src="santa-biblia_html(1).html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <platform name="android">
        <preference name="GradleVersion" value="9.3.1" />
        <icon src="www/img/app_icon.png" density="ldpi" />
        <icon src="www/img/app_icon.png" density="mdpi" />
        <icon src="www/img/app_icon.png" density="hdpi" />
        <icon src="www/img/app_icon.png" density="xhdpi" />
        <icon src="www/img/app_icon.png" density="xxhdpi" />
        <icon src="www/img/app_icon.png" density="xxxhdpi" />
    </platform>
</widget>
